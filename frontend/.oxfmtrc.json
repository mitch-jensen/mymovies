{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    "pnpm-lock.yaml",
    "openapi.yaml",
    "src/client",
    "src/routeTree.gen.ts"
  ]
}
